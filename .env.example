# Copy to .env and edit. All optional — docker-compose.yml has safe defaults.

# Public URL of the app (used to build share links). Set to your domain:
# BASE_URL=https://upload.cis-internal.org

# Port the container listens on (default 8080)
# PORT=8080

# Max upload size in bytes (default 104857600 = 100 MiB)
# MAX_UPLOAD_BYTES=104857600

# How long files are kept before auto-delete (default 720h = 30 days)
# RETENTION=720h
